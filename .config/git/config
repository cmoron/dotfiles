[alias]
    tree = log --oneline --graph --decorate --all
    treee = log --graph --decorate --all --abbrev-commit --pretty=format:'%C(auto)%h%d %s %Cgreen(%cr) %C(bold blue)<%an>%Creset'
    b = branch --all -vv
    s = status
    st = status
    c = commit -m
    co = checkout
    sw = switch
    d = diff
    ds = diff --staged
    a = add
    rb = rebase
    amend = commit --amend --no-edit
    fix = commit --fixup

[user]
    email = cyril.moron@gmail.com
    name = Cyril Moron
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
[pull]
    rebase = true
[init]
	defaultBranch = main
[credential]
	helper = store
[core]
	pager = delta
[fetch]
	prune = true
[rebase]
	autoStash = true
[branch]
	autoSetupRebase = always
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
	pager = less -FRX
